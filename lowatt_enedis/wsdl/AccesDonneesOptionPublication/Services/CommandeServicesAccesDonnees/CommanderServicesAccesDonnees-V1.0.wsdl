            </wsdl:output>
            <wsdl:fault name="erreur">
                <soap:fault name="erreur" use="literal"/>
            </wsdl:fault>
        </wsdl:operation>
    </wsdl:binding>

    <!-- service -->
    <wsdl:service name="CommanderServicesAccesDonnees-V1.0">
        <wsdl:port name="CommanderServicesAccesDonneesPort" binding="tns:CommanderServicesAccesDonneesBinding">
            <soap:address location="https://sge-ws.enedis.fr/CommandeServicesAccesDonnees/v1.0"/>
